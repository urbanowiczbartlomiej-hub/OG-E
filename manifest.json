{
  "manifest_version": 3,
  "name": "OG-E",
  "version": "1.0.3",
  "description": "UI helper for OGame: floating Send Exp/Col, galaxy scan tracker, abandon overlay. Requires AntiGameReborn. Unofficial.",
  "browser_specific_settings": {
    "gecko": {
      "id": "og-e@ogame-extensions",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.ogame.gameforge.com/*",
    "https://api.github.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["histogram.html", "histogram.js", "icons/*.png"],
      "matches": ["*://*.ogame.gameforge.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["*://*.ogame.gameforge.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["*://*.ogame.gameforge.com/game/index.php*"],
      "js": ["page.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
