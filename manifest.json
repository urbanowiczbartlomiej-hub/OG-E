{
  "manifest_version": 3,
  "name": "OG-E: OGame Expedition Helper",
  "version": "4.9.6",
  "description": "OGame UI modification (requires AntiGameReborn): large mobile-friendly buttons that map each tap to one native game button (expedition / colonization missions), colony size histogram built from planets you visit, local database of galaxy positions recorded from systems you navigate to yourself, cross-device sync of your collected data via your own private GitHub Gist. Does not initiate game requests, does not automate gameplay.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.ogame.gameforge.com/*",
    "https://api.github.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["histogram.html", "histogram.js"],
      "matches": ["*://*.ogame.gameforge.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.ogame.gameforge.com/*"
      ],
      "js": [
        "mobile.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "*://*.ogame.gameforge.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.ogame.gameforge.com/*"
      ],
      "js": [
        "sync.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "*://*.ogame.gameforge.com/game/index.php*"
      ],
      "js": [
        "fleet-redirect.js",
        "colonize.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.ogame.gameforge.com/game/index.php*"
      ],
      "js": [
        "settings.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
