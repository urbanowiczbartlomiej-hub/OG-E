{
  "manifest_version": 3,
  "name": "OG-E v5 (dev)",
  "version": "5.0.0",
  "description": "OGame UI modification (requires AntiGameReborn). Clean-slate rewrite of OG-E. Does not initiate game requests, does not automate gameplay.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.ogame.gameforge.com/*",
    "https://api.github.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["histogram.html", "histogram.js"],
      "matches": ["*://*.ogame.gameforge.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["*://*.ogame.gameforge.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["*://*.ogame.gameforge.com/game/index.php*"],
      "js": ["page.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
